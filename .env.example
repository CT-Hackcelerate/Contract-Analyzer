# Copy this file to ".env" and fill in your key.

# Required: your Anthropic API key (https://console.anthropic.com/).
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: model to use for analysis (defaults to claude-sonnet-4-5-20250929).
# ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Optional: port for the web server (defaults to 3000).
# PORT=3000

# Optional: max output tokens per model request (defaults to 16000; long
# responses auto-continue regardless).
# MAX_TOKENS=16000

# Optional: rate limiting for the /analyze endpoint (defaults: 20 per 60000 ms).
# RATE_MAX=20
# RATE_WINDOW_MS=60000

# Optional: USD per 1M tokens, used only for the logged cost estimate.
# PRICE_PER_MTOK_IN=3
# PRICE_PER_MTOK_OUT=15

# Optional: set to 1 to disable the deterministic analysis cache (forces a
# fresh model call every time). Leave unset so the same contract always yields
# the same result even after clearing the output/ folder.
# DISABLE_CACHE=0
